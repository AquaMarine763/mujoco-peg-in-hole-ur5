<mujoco model="ur5e_peg_in_hole_full">
  <!--
    Full UR5e peg-in-hole adapter based on DeepMind MuJoCo Menagerie
    universal_robots_ur5e/ur5e.xml.

    Compared with assets/ur5e_adapter/ur5e_peg_in_hole.xml this model vendors
    the UR5e visual meshes and keeps the Menagerie inertials, actuator style,
    and collision layout. It also exposes the task-facing names expected by
    PegInHoleMujocoEnv.
  -->
  <compiler angle="radian" meshdir="assets" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <global offwidth="2560" offheight="1440"/>
  </visual>

  <custom>
    <numeric name="ik_joint_count" data="6"/>
  </custom>

  <default>
    <default class="ur5e">
      <material specular="0.5" shininess="0.25"/>
      <joint axis="0 1 0" range="-6.28319 6.28319" armature="0.1" limited="true"/>
      <general
        gaintype="fixed"
        biastype="affine"
        ctrlrange="-6.2831 6.2831"
        gainprm="2000"
        biasprm="0 -2000 -400"
        forcerange="-150 150"/>
      <geom friction="1.0 0.005 0.0001" solref="0.01 1" solimp="0.95 0.95 0.001"/>
      <default class="size3">
        <default class="size3_limited">
          <joint range="-3.1415 3.1415"/>
          <general ctrlrange="-3.1415 3.1415"/>
        </default>
      </default>
      <default class="size1">
        <general gainprm="500" biasprm="0 -500 -100" forcerange="-28 28"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="capsule" group="3"/>
        <default class="eef_collision">
          <geom type="cylinder"/>
        </default>
      </default>
      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
    </default>
  </default>

  <asset>
    <material class="ur5e" name="black" rgba="0.033 0.033 0.033 1"/>
    <material class="ur5e" name="jointgray" rgba="0.278 0.278 0.278 1"/>
    <material class="ur5e" name="linkgray" rgba="0.82 0.82 0.82 1"/>
    <material class="ur5e" name="urblue" rgba="0.49 0.678 0.8 1"/>

    <material name="mat_floor" rgba="0.42 0.43 0.44 1"/>
    <material name="mat_table" rgba="0.22 0.25 0.27 1"/>
    <material name="mat_hole" rgba="0.55 0.55 0.52 1"/>
    <material name="mat_peg" rgba="0.1 0.28 0.85 1"/>
    <material name="mat_camera" rgba="0.02 0.02 0.02 1"/>

    <mesh file="base_0.obj"/>
    <mesh file="base_1.obj"/>
    <mesh file="shoulder_0.obj"/>
    <mesh file="shoulder_1.obj"/>
    <mesh file="shoulder_2.obj"/>
    <mesh file="upperarm_0.obj"/>
    <mesh file="upperarm_1.obj"/>
    <mesh file="upperarm_2.obj"/>
    <mesh file="upperarm_3.obj"/>
    <mesh file="forearm_0.obj"/>
    <mesh file="forearm_1.obj"/>
    <mesh file="forearm_2.obj"/>
    <mesh file="forearm_3.obj"/>
    <mesh file="wrist1_0.obj"/>
    <mesh file="wrist1_1.obj"/>
    <mesh file="wrist1_2.obj"/>
    <mesh file="wrist2_0.obj"/>
    <mesh file="wrist2_1.obj"/>
    <mesh file="wrist2_2.obj"/>
    <mesh file="wrist3.obj"/>
  </asset>

  <worldbody>
    <light name="key_light" pos="0.2 -0.5 1.7" dir="-0.2 0.4 -1" diffuse="0.9 0.9 0.85"/>
    <light name="fill_light" pos="0.8 0.6 1.2" dir="-0.5 -0.4 -1" diffuse="0.35 0.38 0.42"/>
    <camera name="overview" pos="1.25 -1.05 1.2" xyaxes="0.65 0.76 0 -0.34 0.29 0.89" fovy="45"/>

    <geom name="floor" type="plane" size="2 2 0.02" material="mat_floor"/>
    <geom name="table_top" type="box" pos="0.575 0 0.60" size="0.325 0.35 0.025" material="mat_table"/>

    <body name="hole_body" mocap="true" pos="0.55 0.05 0.65">
      <geom name="hole_plate" type="box" pos="0 0 -0.012" size="0.085 0.085 0.008" material="mat_hole"/>
      <geom name="hole_north" type="box" pos="0 0.057 0.012" size="0.085 0.012 0.026" material="mat_hole"/>
      <geom name="hole_south" type="box" pos="0 -0.057 0.012" size="0.085 0.012 0.026" material="mat_hole"/>
      <geom name="hole_east" type="box" pos="0.057 0 0.012" size="0.012 0.045 0.026" material="mat_hole"/>
      <geom name="hole_west" type="box" pos="-0.057 0 0.012" size="0.012 0.045 0.026" material="mat_hole"/>
      <site name="hole_site" pos="0 0 0" size="0.008" rgba="0.9 0.1 0.1 1"/>
    </body>

    <body name="base" pos="0.136 -0.223 0.602" childclass="ur5e">
      <inertial mass="4.0" pos="0 0 0" diaginertia="0.00443333156 0.00443333156 0.0072"/>
      <geom mesh="base_0" material="black" class="visual"/>
      <geom mesh="base_1" material="jointgray" class="visual"/>
      <geom name="base_geom" type="cylinder" size="0.075 0.055" group="3"/>

      <body name="shoulder_link" pos="0 0 0.163">
        <inertial mass="3.7" pos="0 0 0" diaginertia="0.0102675 0.0102675 0.00666"/>
        <joint name="shoulder_pan" class="size3" axis="0 0 1"/>
        <geom mesh="shoulder_0" material="urblue" class="visual"/>
        <geom mesh="shoulder_1" material="black" class="visual"/>
        <geom mesh="shoulder_2" material="jointgray" class="visual"/>
        <geom name="shoulder_geom" class="collision" size="0.06 0.06" pos="0 0 -0.04"/>

        <body name="upper_arm_link" pos="0 0.138 0" quat="1 0 1 0">
          <inertial mass="8.393" pos="0 0 0.2125" diaginertia="0.133886 0.133886 0.0151074"/>
          <joint name="shoulder_lift" class="size3"/>
          <geom mesh="upperarm_0" material="linkgray" class="visual"/>
          <geom mesh="upperarm_1" material="black" class="visual"/>
          <geom mesh="upperarm_2" material="jointgray" class="visual"/>
          <geom mesh="upperarm_3" material="urblue" class="visual"/>
          <geom name="upper_arm_shoulder_geom" class="collision" pos="0 -0.04 0" quat="1 1 0 0" size="0.06 0.06"/>
          <geom name="upper_arm_geom" class="collision" size="0.05 0.2" pos="0 0 0.2"/>

          <body name="forearm_link" pos="0 -0.131 0.425">
            <inertial mass="2.275" pos="0 0 0.196" diaginertia="0.0311796 0.0311796 0.004095"/>
            <joint name="elbow" class="size3_limited"/>
            <geom mesh="forearm_0" material="urblue" class="visual"/>
            <geom mesh="forearm_1" material="linkgray" class="visual"/>
            <geom mesh="forearm_2" material="black" class="visual"/>
            <geom mesh="forearm_3" material="jointgray" class="visual"/>
            <geom name="forearm_elbow_geom" class="collision" pos="0 0.08 0" quat="1 1 0 0" size="0.055 0.06"/>
            <geom name="forearm_geom" class="collision" size="0.038 0.19" pos="0 0 0.2"/>

            <body name="wrist_1_link" pos="0 0 0.392" quat="1 0 1 0">
              <inertial mass="1.219" pos="0 0.127 0" diaginertia="0.0025599 0.0025599 0.0021942"/>
              <joint name="wrist_1" class="size1"/>
              <geom mesh="wrist1_0" material="black" class="visual"/>
              <geom mesh="wrist1_1" material="urblue" class="visual"/>
              <geom mesh="wrist1_2" material="jointgray" class="visual"/>
              <geom name="wrist_1_geom" class="collision" pos="0 0.05 0" quat="1 1 0 0" size="0.04 0.07"/>

              <body name="wrist_2_link" pos="0 0.127 0">
                <inertial mass="1.219" pos="0 0 0.1" diaginertia="0.0025599 0.0025599 0.0021942"/>
                <joint name="wrist_2" axis="0 0 1" class="size1"/>
                <geom mesh="wrist2_0" material="black" class="visual"/>
                <geom mesh="wrist2_1" material="urblue" class="visual"/>
                <geom mesh="wrist2_2" material="jointgray" class="visual"/>
                <geom name="wrist_2_base_geom" class="collision" size="0.04 0.06" pos="0 0 0.04"/>
                <geom name="wrist_2_geom" class="collision" pos="0 0.02 0.1" quat="1 1 0 0" size="0.04 0.04"/>

                <body name="wrist_3_link" pos="0 0 0.1">
                  <inertial
                    mass="0.1889"
                    pos="0 0.0771683 0"
                    quat="1 0 0 1"
                    diaginertia="0.000132134 9.90863e-05 9.90863e-05"/>
                  <joint name="wrist_3" class="size1"/>
                  <geom material="linkgray" mesh="wrist3" class="visual"/>
                  <geom name="wrist_3_geom" class="eef_collision" pos="0 0.08 0" quat="1 1 0 0" size="0.04 0.02"/>

                  <body name="tool0" pos="0 0.1 0" quat="0 1 0 0">
                    <geom name="camera_geom" type="box" pos="-0.02 0 0.055" size="0.018 0.018 0.018" material="mat_camera" density="200" contype="0" conaffinity="0"/>
                    <geom name="peg_geom" type="capsule" fromto="0 0 0 0 0 -0.11" size="0.012" material="mat_peg" density="780"/>
                    <site name="eef_site" pos="0 0 0" size="0.01" rgba="0 0.8 0.2 1"/>
                    <site name="peg_tip" pos="0 0 -0.11" size="0.008" rgba="0.1 0.9 0.1 1"/>
                    <camera
                      name="wrist_cam"
                      pos="-0.09 0.12 0.16"
                      xyaxes="-0.548392 0.766151 0.335081 -0.835508 -0.518563 -0.181712"
                      fovy="100"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general class="size3" name="shoulder_pan_ctrl" joint="shoulder_pan"/>
    <general class="size3" name="shoulder_lift_ctrl" joint="shoulder_lift"/>
    <general class="size3_limited" name="elbow_ctrl" joint="elbow"/>
    <general class="size1" name="wrist_1_ctrl" joint="wrist_1"/>
    <general class="size1" name="wrist_2_ctrl" joint="wrist_2"/>
    <general class="size1" name="wrist_3_ctrl" joint="wrist_3"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0" ctrl="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0"/>
  </keyframe>
</mujoco>
